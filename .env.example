# 32-byte hex secret used to encrypt/decrypt each user's stored Featherless/Horde API keys.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_MASTER_KEY=

PORT=4113

# Parallel worker dispatch (lorepebble-style lanes). Workers pause while Featherless prose runs.
WORKER_THREADS=4
PROSE_THREADS=1

# Cline worker MCP server (src/mcp/cline-worker.ts) — gives Cline access to a cheap
# 1-slot Featherless model for lightweight code lookup tasks. Uses a separate API key
# from the per-user encrypted keys, since this is a dev tool, not a Loremaster feature.
CLINE_WORKER_API_KEY=
CLINE_WORKER_MODEL=NousResearch/Hermes-3-Llama-3.1-8B
