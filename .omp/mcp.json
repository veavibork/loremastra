{
  "$schema": "https://raw.githubusercontent.com/can1357/oh-my-pi/main/packages/coding-agent/src/config/mcp-schema.json",
  "mcpServers": {
    "loremaster-dev": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "tsx", "src/mcp/dev-server.ts"]
    },
    "context7": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@upstash/context7-mcp"]
    },
    "cline-worker": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "tsx", "src/mcp/cline-worker.ts"]
    }
  }
}
