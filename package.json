{
  "name": "loremaster",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "db:init": "tsx scripts/init-db.ts",
    "user:create": "tsx scripts/create-user.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cross-env DEV_BYPASS_SESSION_GUARD=true playwright test",
    "start": "node dist/src/index.js",
    "lint": "oxlint src scripts",
    "format": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "server:restart": "node scripts/dev-restart.mjs",
    "server:reset-db": "node scripts/dev-reset-db.mjs",
    "server:fresh": "node scripts/dev-reset-db.mjs && node scripts/dev-restart.mjs",
    "mcp": "tsx src/mcp/dev-server.ts",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@hono/standard-validator": "^0.2.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.3.0",
    "hono": "^4.6.3",
    "uuid": "^11.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "lint-staged": "^16.2.6",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
